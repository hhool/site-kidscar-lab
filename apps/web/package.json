{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1 --port 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run lint && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "content:snapshot:seed": "tsx scripts/content-snapshot.ts seed",
    "content:snapshot:update": "tsx scripts/content-snapshot.ts update",
    "content:snapshot:export": "tsx scripts/content-snapshot.ts export",
    "e2e:auth": "node scripts/e2e-auth.mjs",
    "test:ui": "playwright test",
    "e2e:ui": "npm run build && npm run test:ui",
    "e2e": "npm run e2e:auth && npm run test:ui"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
